{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sticky-footer",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/portfolio/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*.pdf",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.devndespro.com" }],
      "destination": "https://devndespro.com/:1",
      "permanent": true
    }
  ],
  "cleanUrls": true
}