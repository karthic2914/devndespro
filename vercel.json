{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sticky-footer",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/portfolio/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*.pdf",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/#contact",
      "permanent": true
    }
  ]
}