{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/seo/:slug(.*).html",
      "destination": "/seo/:slug",
      "permanent": true
    },
    {
      "source": "/blog/:slug(.*).html",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sticky-footer",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/portfolio/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*.pdf",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/#contact",
      "permanent": true
    }
  ],
  "cleanUrls": true
}